# DeepSeek / OpenAI 兼容 API
EVA_API_KEY=your-api-key-here
EVA_BASE_URL=https://api.deepseek.com
EVA_MODEL_NAME=deepseek-reasoner

# Neon PostgreSQL（Railway Variables 中配置，勿提交真实连接串）
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# 可选：自定义 EVA 全局配置目录
# EVA_HOME=/app/data/.eva

# 可选：本地持久化目录（未配置 DATABASE_URL 时使用）
# EVA_DATA_DIR=./data

# 微信 Bot 凭证本地缓存路径（登录后会同步到数据库）
# WECHATBOT_CRED_PATH=/app/data/wechatbot/credentials.json

# EVA 单次任务超时（秒），默认 600
# EVA_TASK_TIMEOUT=600
